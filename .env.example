PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/uav_logistics

DB_DRIVER=org.postgresql.Driver

DB_USER=uav

DB_PASSWORD=uav



BACKEND_URL=http://localhost:8080

FRONTEND_START_ON_BACKEND=true

FRONTEND_DEV_SERVER_HOST=127.0.0.1

FRONTEND_DEV_SERVER_PORT=8081

AGENT_ID=uav-1

AGENT_TYPE=UAV

PX4_CONNECTION=udp://:14540

TELEMETRY_PERIOD_MS=1000

POLLING_PERIOD_MS=2000

AGENT_CHARGE_PERCENT_PER_SECOND=1.0

AGENT_MIN_ROUTE_ENERGY_SPEND_PERCENT=0.5



AGENT_RUNTIME_MODE=docker

PROJECT_ROOT=C:\Users\Szymon\Documents\Magisterka\Projekt

BACKEND_PUBLIC_URL=http://host.docker.internal:8080



SIMULATION_GAZEBO_ENABLED=true

SIMULATION_GAZEBO_START_ON_BACKEND=false

SIMULATION_GAZEBO_STARTUP_DELAY_MS=7000

SIMULATION_RESTORE_AGENT_VISUALS=false

SIMULATION_COMPLETED_PACKAGE_DESPAWN_DELAY_MS=5000

SIM_ORIGIN_LAT=47.397971

SIM_ORIGIN_LON=8.546164

GZ_WORLD=default

# PX4 mission navigation (default: mission). Climb before horizontal legs; NAV_LAND at packages/stations.
AGENT_NAV_MODE=mission
UAV_PRECISION_LANDING=true
UAV_LAND_ACCEPTANCE_RADIUS_M=2
UAV_MISSION_ACCEPTANCE_RADIUS_M=5
SIM_CARGO_MIN_AIR_Z_M=2.0

# Horizontal route avoidance (UGV + UAV): detour around other agents; lateral recovery if stuck mid-route.
# UAV peers count as obstacles even while docked at the same hub (shared departures).
GROUND_OBSTACLE_AVOIDANCE=true
GROUND_OBSTACLE_UAV_RADIUS_M=6.0
GROUND_OBSTACLE_UGV_RADIUS_M=2.5
GROUND_OBSTACLE_CLEARANCE_M=1.5
GROUND_OBSTACLE_MIN_DETOUR_M=5.0
GROUND_OBSTACLE_EXCLUDE_DOCKED=true

GZ_PARTITION=uav-logistics

